---
import { getEntry } from 'astro:content';
import '../styles/global.css';

const { title, description } = Astro.props;
const pageTitle = title ? `Vansh Kumar | ${title}` : 'Vansh Kumar';
const pathname = Astro.url.pathname;
const isTerrain = pathname === '/terrain';
const siteEntry = await getEntry('pages', 'site');
const brandSubtitle =
  siteEntry?.data?.brandSubtitle ?? 'Notes, projects, and quiet experiments.';
const pageDescription = description?.trim() || brandSubtitle;
const siteUrl = 'https://vanshkumar.net';
const ogImage = `${siteUrl}/og.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta property="og:site_name" content="Vansh Kumar" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={`${siteUrl}${pathname}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href="/brand/vk_logo.png" />
    <link rel="apple-touch-icon" href="/brand/vk_logo.png" />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header-inner">
          <div class="brand">
            <a href="/">Vansh Kumar</a>
            <span class="brand-subtitle">{brandSubtitle}</span>
          </div>
          <nav class="site-nav" aria-label="Primary">
            <a href="/about" class:list={['nav-link', pathname === '/about' && 'is-active']}>About</a>
            <a href="/now" class:list={['nav-link', pathname === '/now' && 'is-active']}>Now</a>
            <a href="/contact" class:list={['nav-link', pathname === '/contact' && 'is-active']}>Contact</a>
            <a href="/shelf" class:list={['nav-link', pathname === '/shelf' && 'is-active']}>Shelf</a>
            <a
              href="/terrain"
              class:list={['nav-link', 'nav-pill', isTerrain && 'is-active']}
            >
              <span class="nav-icon" aria-hidden="true">🌱</span>
              Terrain
            </a>
          </nav>
        </div>
      </header>

      <div class="page">
        <main class="content">
          <slot />
        </main>
      </div>

      <footer class="site-footer">
        <div class="site-footer-inner">
          <div class="site-footer-brand">
            <span class="site-footer-icon" aria-hidden="true">
              <img src="/brand/vk_logo.png" alt="VK logo" />
            </span>
          </div>
          <nav class="site-footer-links" aria-label="Footer">
            <a href="/now">Quest(ion)s</a>
            <a href="https://x.com/lunchwithav" rel="me noopener noreferrer" target="_blank" class="external-link">Twitter</a>
            <a href="https://vanshkumar.substack.com/" rel="noopener noreferrer" target="_blank" class="external-link">Substack</a>
            <a href="/rss.xml">RSS</a>
          </nav>
        </div>
      </footer>
    </div>
  </body>
</html>
