---
const { title, target, message = 'This page moved' } = Astro.props;
const canonicalUrl = new URL(target, Astro.site ?? Astro.url.origin);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>
  </head>
  <body>
    <p>{message} to <a href={target}>{target}</a>.</p>
  </body>
</html>
