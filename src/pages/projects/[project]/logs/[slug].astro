---
import { getCollection } from 'astro:content';
import RedirectLayout from '../../../../layouts/RedirectLayout.astro';
import { titleFromSlug } from '../../../../lib/content';

export async function getStaticPaths() {
  const entries = await getCollection('logs');
  return entries.map((entry) => {
    const [project, slug] = entry.slug.split('/');
    return {
      params: { project, slug },
      props: {
        title: entry.data.title ?? entry.data.day ?? titleFromSlug(slug),
        target: `/terrain/${project}/logs/${slug}`
      }
    };
  });
}

const { title, target } = Astro.props;
---

<RedirectLayout title={title} target={target} message="This project log moved" />
