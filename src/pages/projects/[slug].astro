---
import { getCollection } from 'astro:content';
import RedirectLayout from '../../layouts/RedirectLayout.astro';
import { titleFromSlug } from '../../lib/content';

export async function getStaticPaths() {
  const entries = await getCollection('terrain');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: {
      title: entry.data.title ?? titleFromSlug(entry.slug),
      target: `/terrain/${entry.slug}`
    }
  }));
}

const { title, target } = Astro.props;
---

<RedirectLayout title={title} target={target} message="This post moved" />
