---
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { getBacklinksForEntry } from '../../lib/wiki';
import { titleFromSlug } from '../../lib/content';

export async function getStaticPaths() {
  const entries = await getCollection('projects');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const allLogs = await getCollection('logs');
const logs = allLogs
  .filter((log) => log.data.parent === entry.slug)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const backlinks = await getBacklinksForEntry('projects', entry.slug);
const title = entry.data.title ?? titleFromSlug(entry.slug);
const lastUpdated = entry.data.lastmod ?? entry.data.date ?? null;

const formatDate = (date) =>
  new Intl.DateTimeFormat('en-US', {
    dateStyle: 'medium',
    timeZone: 'UTC'
  }).format(date);
const subtype = entry.data.kind
  ? entry.data.kind[0].toUpperCase() + entry.data.kind.slice(1)
  : 'Essay';
const logHref = (log) => {
  const [, slug] = log.slug.split('/');
  return `/projects/${entry.slug}/logs/${slug}`;
};
const logTitle = (log) => log.data.title ?? log.data.day ?? formatDate(log.data.date);
const comic = entry.data.comic;
const comicPageSrc = (assetDir, page) => {
  const webDir = path.join(process.cwd(), 'public', 'assets', assetDir, 'web');
  const optimizedExtension = ['webp', 'jpg', 'png'].find((extension) =>
    fs.existsSync(path.join(webDir, `${page}.${extension}`))
  );

  if (optimizedExtension) {
    return `/assets/${assetDir}/web/${page}.${optimizedExtension}`;
  }

  return `/assets/${assetDir}/${page}.png`;
};
const comicReader = comic
  ? {
      assetDir: comic.assetDir,
      title,
      width: comic.width,
      height: comic.height,
      pages: Array.from({ length: comic.pageCount }, (_, index) => {
        const page = index + 1;
        const src = comicPageSrc(comic.assetDir, page);
        return {
          page,
          src,
          originalSrc: src,
          alt:
            page === 1
              ? `${title} cover`
              : `${title} page ${page}`
        };
      })
    }
  : null;
---

<ContentLayout
  title={title}
  description={entry.data.description}
  date={entry.data.date}
  kind={subtype}
  lastUpdated={lastUpdated}
  showDateRange
  backlinks={backlinks}
>
  <Content />
  {comicReader ? (
    <>
      <script
        type="application/json"
        id={`comic-reader-data-${comicReader.assetDir}`}
        set:html={JSON.stringify(comicReader)}
      />
      <script is:inline>
        (() => {
          const dataScript = document.currentScript?.previousElementSibling;
          if (!(dataScript instanceof HTMLScriptElement)) return;

          const reader = JSON.parse(dataScript.textContent || '{}');
          const mount = document.querySelector(
            `[data-comic-reader="${reader.assetDir}"]`
          );
          if (!mount || !Array.isArray(reader.pages) || !reader.pages.length) return;

          let viewIndex = 0;
          const totalViews = 1 + Math.ceil((reader.pages.length - 1) / 2);

          const root = document.createElement('section');
          root.className = 'comic-reader';
          root.setAttribute('aria-label', `${reader.title} comic reader`);

          const stage = document.createElement('div');
          stage.className = 'comic-reader-stage';

          const status = document.createElement('p');
          status.className = 'comic-reader-status';
          status.setAttribute('aria-live', 'polite');

          const previousButton = document.createElement('button');
          previousButton.className = 'comic-reader-button';
          previousButton.type = 'button';
          previousButton.textContent = 'Previous';

          const nextButton = document.createElement('button');
          nextButton.className = 'comic-reader-button';
          nextButton.type = 'button';
          nextButton.textContent = 'Next';

          const controls = document.createElement('div');
          controls.className = 'comic-reader-controls';
          controls.append(previousButton, status, nextButton);

          root.append(stage, controls);
          mount.replaceChildren(root);

          const resizeComicReader = () => {
            const viewportHeight =
              window.visualViewport?.height ?? window.innerHeight;
            const rootStyles = window.getComputedStyle(root);
            const verticalPadding =
              parseFloat(rootStyles.paddingTop) +
              parseFloat(rootStyles.paddingBottom);
            const controlsHeight = controls.getBoundingClientRect().height;
            const breathingRoom = 24;
            const availableHeight =
              viewportHeight -
              controlsHeight -
              verticalPadding -
              breathingRoom;

            root.style.setProperty(
              '--comic-page-max-height',
              `${Math.max(120, Math.floor(availableHeight))}px`
            );
          };

          const pagesForView = (index) => {
            if (index === 0) return [reader.pages[0]];
            const start = 1 + (index - 1) * 2;
            return reader.pages.slice(start, start + 2);
          };

          const labelForPages = (pages) => {
            if (pages.length === 1 && pages[0].page === 1) return 'Cover';
            if (pages.length === 1) return `Page ${pages[0].page}`;
            return `Pages ${pages[0].page}-${pages[1].page}`;
          };

          const preloadView = (index) => {
            if (index < 0 || index >= totalViews) return;
            pagesForView(index).forEach((page) => {
              const image = new Image();
              image.src = page.src;
            });
          };

          const render = () => {
            const pages = pagesForView(viewIndex);
            stage.className = [
              'comic-reader-stage',
              pages.length === 1 ? 'is-single' : 'is-spread'
            ].join(' ');
            stage.replaceChildren(
              ...pages.map((page) => {
                const link = document.createElement('a');
                link.className = 'comic-reader-page-link';
                link.href = page.originalSrc;
                link.target = '_blank';
                link.rel = 'noopener noreferrer';
                link.setAttribute('aria-label', `Open ${page.alt}`);

                const image = document.createElement('img');
                image.className = 'comic-reader-page';
                image.src = page.src;
                image.alt = page.alt;
                image.width = reader.width;
                image.height = reader.height;
                image.decoding = 'async';
                image.loading = viewIndex === 0 ? 'eager' : 'lazy';

                link.append(image);
                return link;
              })
            );

            status.textContent = `${labelForPages(pages)} of ${reader.pages.length}`;
            previousButton.disabled = viewIndex === 0;
            nextButton.disabled = viewIndex === totalViews - 1;

            requestAnimationFrame(resizeComicReader);
            preloadView(viewIndex + 1);
          };

          const goTo = (index) => {
            viewIndex = Math.max(0, Math.min(totalViews - 1, index));
            render();
          };

          previousButton.addEventListener('click', () => goTo(viewIndex - 1));
          nextButton.addEventListener('click', () => goTo(viewIndex + 1));
          root.addEventListener('click', (event) => {
            if (!(event.target instanceof HTMLElement)) return;
            if (event.target.closest('a, button')) return;
            const rect = root.getBoundingClientRect();
            const isRightHalf = event.clientX > rect.left + rect.width / 2;
            goTo(viewIndex + (isRightHalf ? 1 : -1));
          });
          document.addEventListener('keydown', (event) => {
            if (event.key === 'ArrowLeft') goTo(viewIndex - 1);
            if (event.key === 'ArrowRight') goTo(viewIndex + 1);
          });
          window.addEventListener('resize', resizeComicReader);
          window.visualViewport?.addEventListener('resize', resizeComicReader);
          window.addEventListener('orientationchange', () => {
            requestAnimationFrame(resizeComicReader);
          });

          render();
        })();
      </script>
    </>
  ) : null}
  {logs.length ? (
    <section class="section" slot="after-content">
      <h2>Logs</h2>
      <ul class="list">
        {logs.map((log) => (
          <li>
            <a href={logHref(log)}>{logTitle(log)}</a>
            <span class="meta"> {formatDate(log.data.date)}</span>
          </li>
        ))}
      </ul>
    </section>
  ) : null}
</ContentLayout>
