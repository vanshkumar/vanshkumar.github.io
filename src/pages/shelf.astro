---
import { getCollection } from 'astro:content';
import ContentLayout from '../layouts/ContentLayout.astro';
import { titleFromSlug } from '../lib/content';

const title = 'Shelf';
const reviews = (await getCollection('shelf')).sort((a, b) => {
  const aDate = a.data.date ?? a.data.lastmod ?? new Date(0);
  const bDate = b.data.date ?? b.data.lastmod ?? new Date(0);
  return bDate.getTime() - aDate.getTime();
});

const starsForRating = (rating) => '★'.repeat(rating) + '☆'.repeat(5 - rating);
const reviewTitle = (review) => review.data.title ?? titleFromSlug(review.slug);
---

<ContentLayout
  title={title}
>
  {reviews.length ? (
    <div class="shelf-grid" aria-label="Book reviews">
      {reviews.map((review) => {
        const displayTitle = reviewTitle(review);
        const ratingLabel = `${review.data.rating} out of 5 stars`;
        return (
          <a
            class="shelf-book"
            href={`/shelf/${review.slug}`}
            aria-label={`${displayTitle}, ${ratingLabel}`}
          >
            <span
              class:list={[
                'shelf-cover',
                !review.data.coverImage && 'shelf-cover-placeholder'
              ]}
            >
              {review.data.coverImage ? (
                <img
                  src={review.data.coverImage}
                  alt={`${displayTitle} cover`}
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <span class="shelf-cover-title">{displayTitle}</span>
              )}
            </span>
            <span class="shelf-rating" aria-label={ratingLabel}>
              <span aria-hidden="true">{starsForRating(review.data.rating)}</span>
            </span>
          </a>
        );
      })}
    </div>
  ) : null}
</ContentLayout>
