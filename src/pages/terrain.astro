---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';
import { titleFromSlug } from '../lib/content';
import { stripCalloutMarkers } from '../lib/callouts.mjs';

const entry = await getEntry('pages', 'terrain');
if (!entry) {
  throw new Error('Missing content entry: pages/terrain');
}
const { Content } = await entry.render();
const pageLastUpdated = entry.data.lastmod;
const heroTitle = entry.data.heroTitle ?? null;
const heroAccent = entry.data.heroAccent ?? null;
const hasHeroBody = Boolean(entry.body?.trim());
const isAccentOnlyHero = !heroTitle && heroAccent;

const terrainEntries = await getCollection('terrain');
const hasTag = (entry, tag) =>
  (entry.data.tags ?? []).some((value) => value.toLowerCase() === tag);
const projects = terrainEntries.filter(
  (entry) => hasTag(entry, 'projects') || hasTag(entry, 'essays')
);
const questions = terrainEntries.filter((entry) => hasTag(entry, 'questions'));
const hunches = terrainEntries.filter((entry) => hasTag(entry, 'hunches'));

const displayTitle = (entry) => entry.data.title ?? titleFromSlug(entry.slug);
const stripMarkdown = (value) =>
  stripCalloutMarkers(value)
    .replace(/!\[[^\]]*\]\([^)]+\)/g, '')
    .replace(/\[[^\]]+\]\([^)]+\)/g, '')
    .replace(/\[\[([^\]|]+)(?:\|[^\]]+)?\]\]/g, '$1')
    .replace(/[`*_>#-]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();

const excerpt = (value, maxLength = 180) => {
  const text = stripMarkdown(value);
  if (text.length <= maxLength) return text;
  return `${text.slice(0, maxLength).trim()}…`;
};

const formatCardDate = (date) =>
  date
    ? new Intl.DateTimeFormat('en-US', {
        day: '2-digit',
        month: 'short',
        year: 'numeric',
        timeZone: 'UTC'
      })
        .format(date)
        .replace(/,/g, '')
        .toUpperCase()
    : null;

const formatLastUpdated = (date) =>
  date
    ? new Intl.DateTimeFormat('en-CA', {
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
        timeZone: 'UTC'
      }).format(date)
    : null;

const sortByUpdated = (a, b) => {
  const aTime = a.lastUpdated ? a.lastUpdated.getTime() : 0;
  const bTime = b.lastUpdated ? b.lastUpdated.getTime() : 0;
  return bTime - aTime;
};

const toCard = (entry) => {
  const lastUpdated = entry.data.lastmod ?? entry.data.date ?? null;
  return {
    key: `terrain:${entry.slug}`,
    title: displayTitle(entry),
    description: entry.data.description ?? excerpt(entry.body ?? ''),
    date: entry.data.date ?? null,
    dateLabel: formatCardDate(entry.data.date),
    lastUpdated,
    lastUpdatedLabel: formatLastUpdated(lastUpdated),
    href: `/terrain/${entry.slug}`,
    coverImage: entry.data.coverImage ?? null
  };
};

const projectCards = projects.map(toCard).sort(sortByUpdated);
const questionCards = questions.map(toCard).sort(sortByUpdated);
const hunchCards = hunches.map(toCard).sort(sortByUpdated);
---

<BaseLayout title="Terrain">
  <section class="terrain-hero">
    <div class:list={['terrain-hero-content', isAccentOnlyHero && 'terrain-hero-content-accent-only']}>
      <h1 class:list={['terrain-hero-title', isAccentOnlyHero && 'terrain-hero-title-accent-only']}>
        {heroTitle ? <span>{heroTitle}</span> : null}
        {heroAccent ? (
          <span class="terrain-hero-accent">{heroAccent}</span>
        ) : null}
        {!heroTitle && !heroAccent ? <span>{entry.data.title ?? 'Terrain'}</span> : null}
      </h1>
      {hasHeroBody ? (
        <div class="terrain-hero-subtitle">
          <Content />
        </div>
      ) : null}
    </div>
  </section>

  <section class="terrain-map" id="projects">
    <div class="terrain-map-header">
      <h2>Projects & essays</h2>
    </div>

    {projectCards.length === 0 ? (
      <p class="meta">No projects yet.</p>
    ) : (
      <div class="terrain-card-grid">
        {projectCards.map((card) => (
          <article class="terrain-card" key={card.key}>
            {card.dateLabel ? (
              <div class="terrain-card-meta">
                <span class="terrain-card-date">{card.dateLabel}</span>
              </div>
            ) : null}

            {card.coverImage ? (
              <div class="terrain-card-image">
                <img src={card.coverImage} alt="" loading="lazy" />
              </div>
            ) : null}

            <h3 class="terrain-card-title">
              <a href={card.href}>{card.title}</a>
            </h3>
            <p class="terrain-card-description">{card.description}</p>

            <div class="terrain-card-footer">
              <span>{card.lastUpdatedLabel ? `Updated ${card.lastUpdatedLabel}` : ''}</span>
            </div>
          </article>
        ))}
      </div>
    )}
  </section>

  <section class="terrain-map" id="questions">
    <div class="terrain-map-header">
      <h2>Questions</h2>
    </div>

    {questionCards.length === 0 ? (
      <p class="meta">No questions yet.</p>
    ) : (
      <div class="terrain-card-grid">
        {questionCards.map((card) => (
          <article class="terrain-card terrain-card-question" key={card.key}>
            <h3 class="terrain-card-title">
              <a href={card.href}>{card.title}</a>
            </h3>

            <div class="terrain-card-footer">
              <span>{card.lastUpdatedLabel ? `Updated ${card.lastUpdatedLabel}` : ''}</span>
            </div>
          </article>
        ))}
      </div>
    )}
  </section>

  <section class="terrain-map" id="hunches">
    <div class="terrain-map-header">
      <h2>Hunches</h2>
    </div>

    {hunchCards.length === 0 ? (
      <p class="meta">No hunches yet.</p>
    ) : (
      <div class="terrain-card-grid">
        {hunchCards.map((card) => (
          <article class="terrain-card terrain-card-question" key={card.key}>
            <h3 class="terrain-card-title">
              <a href={card.href}>{card.title}</a>
            </h3>

            <div class="terrain-card-footer">
              <span>{card.lastUpdatedLabel ? `Updated ${card.lastUpdatedLabel}` : ''}</span>
            </div>
          </article>
        ))}
      </div>
    )}
  </section>

  {pageLastUpdated ? (
    <div class="content-updated">Last updated {formatLastUpdated(pageLastUpdated)}</div>
  ) : null}
</BaseLayout>
