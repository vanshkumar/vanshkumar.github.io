# Browser-safe Vite configuration.
# This URL is public by design. Do not put tokens or passphrases in any VITE_ variable.
VITE_REFRESH_DISPATCH_URL=
VITE_REFRESH_DOCS_URL=

# Local CLI / GitHub Actions refresh configuration.
# The manifest URL is optional; leave empty to validate and rewrite the current static JSON.
REFRESH_SOURCE_MANIFEST_URL=
REFRESH_UPDATE_TIMESTAMP=true
REFRESH_DRY_RUN=false

# Optional external serverless refresh dispatch backend.
# These values belong only in the serverless host environment, never in the browser bundle.
GITHUB_TOKEN=
GITHUB_OWNER=vanshkumar
GITHUB_REPO=vanshkumar.github.io
GITHUB_REF=feat/tennis-prize-economics-dashboard
REFRESH_WORKFLOW_ID=tennis-prize-money-refresh.yml
REFRESH_TOKEN=
REFRESH_ALLOWED_ORIGIN=
