{
  "name": "vault-weather",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "install:plugin": "npm run build && node scripts/install-plugin.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && npm run typecheck"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "esbuild": "^0.25.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.14.0",
    "obsidian": "^1.8.7",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^1.3.1"
  }
}
